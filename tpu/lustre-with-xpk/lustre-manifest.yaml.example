# ============================================================================
# Example PV/PVC manifest for Managed Lustre on GKE
#
# This file is auto-generated by: ./xpk-lustre-setup.sh manifest
# You do NOT need to create this manually — the script fetches all values
# from your Lustre instance via gcloud.
#
# If you prefer to create it manually, replace the placeholders below.
# ============================================================================
apiVersion: v1
kind: PersistentVolume
metadata:
  name: xpk-lustre-pv
spec:
  storageClassName: ""                  # MUST be empty string for static provisioning
  capacity:
    storage: 18000Gi                    # Must match Lustre instance capacity
  accessModes:
    - ReadWriteMany                     # Lustre supports concurrent read/write
  persistentVolumeReclaimPolicy: Retain # Keep data when PV is released
  volumeMode: Filesystem
  claimRef:
    namespace: default                  # Must match workload namespace
    name: xpk-lustre-pvc               # Must match PVC name below
  csi:
    driver: lustre.csi.storage.gke.io
    volumeHandle: "projects/YOUR_PROJECT/locations/YOUR_ZONE/instances/YOUR_INSTANCE"
    volumeAttributes:
      ip: "YOUR_LUSTRE_IP"             # From: gcloud lustre instances describe ...
      filesystem: "YOUR_FS_NAME"       # From mountPoint field (e.g., "lustrefs", "lfs")
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: xpk-lustre-pvc
  namespace: default                    # Must match claimRef.namespace in PV
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""                  # MUST be empty string
  volumeName: xpk-lustre-pv            # Must match PV name above
  resources:
    requests:
      storage: 18000Gi                  # Must match PV capacity
