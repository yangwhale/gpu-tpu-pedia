#!/bin/bash
# ============================================================================
# Example environment file for xpk-lustre-setup.sh
# Copy this file to env.sh and modify the values for your environment.
#
#   cp env.sh.example env.sh
#   vim env.sh
#   source env.sh && ./xpk-lustre-setup.sh all
# ============================================================================

# Required: GCP project and zone
export PROJECT_ID="my-project-id"
export LOCATION="us-central2-b"

# Required: GKE cluster name (will be created)
export CLUSTER_NAME="my-lustre-cluster"

# Required: Existing Managed Lustre instance name
export LUSTRE_INSTANCE="my-lustre-instance"

# Required: VPC network and subnet (must match Lustre instance's network)
export NETWORK_NAME="my-vpc-network"
export SUBNET_NAME="my-subnet"

# Optional: Cluster settings
# export GKE_VERSION="1.33.5-gke.2469000"
# export DEVICE_TYPE="n2-standard-32-1"     # CPU node for testing
# export DEVICE_TYPE="v6e-16"               # TPU v6e for training
# export CAPACITY_TYPE="on-demand"          # on-demand | spot | reservation=NAME
# export NUM_SLICES=1

# Optional: Lustre mount settings
# export MOUNT_POINT="/lustre-data"

# Optional: Test workload settings
# export TEST_WORKLOAD_NAME="lustre-mount-test"
# export DOCKER_IMAGE="ubuntu:22.04"
